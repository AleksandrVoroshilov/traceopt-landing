---

<div class="hero-pin-wrap">
    <section class="hero" data-screen-label="01 hero">
        <div class="hero-left">
            <div class="meta">
                <span><b>Traceopt</b> / 2026</span>
                <span>Heat tracing · Routing</span>
                <span>Engineering as a service</span>
                <span>Not a CAD plugin</span>
            </div>

            <div class="headline">
                <h1 class="display">
                    Optimal<br />tracer routing,<br /><em
                        >computed<span class="ping-dot"></span></em
                    >
                </h1>
                <p class="lede">
                    You send piping data and the tracing brief.<br />
                    We return optimized tracer circuits as (x, y, z) polylines.
                </p>
                <div class="cta-row">
                    <a href="#contact" class="btn btn-primary btn-lg"
                        >Send brief →</a
                    >
                    <a href="#datasheet" class="btn btn-ghost btn-lg"
                        >Datasheet</a
                    >
                </div>
                <div class="note">
                    Reply within 1 business day · Pilot is free
                </div>
            </div>

            <div class="stats">
                <div class="s">
                    <div class="n">−9.7<sup>%</sup></div><div class="l">
                        Tracer length<br />vs manual baseline
                    </div>
                </div>
                <div class="s">
                    <div class="n">&lt;5<sup>min</sup></div><div class="l">
                        Solve time<br /><b>1 000</b> segments
                    </div>
                </div>
                <div class="s">
                    <div class="n">06<sup>/6</sup></div><div class="l">
                        Circuits returned<br />fully satisfied
                    </div>
                </div>
                <div class="s">
                    <div class="n">80<sup>%</sup></div><div class="l">
                        Manual routing<br />industry baseline
                    </div>
                </div>
            </div>

            <span class="hero-stub" aria-hidden="true"></span>
        </div>

        <div class="hero-right" id="hero-canvas-wrap">
            <canvas
                id="hero-canvas"
                aria-hidden="true"
                style="display:block;width:100%;height:100%"></canvas>
            <svg
                id="hero-svg-overlay"
                viewBox="0 0 1024 1024"
                preserveAspectRatio="xMidYMid meet"
                aria-hidden="true"
            >
                <g class="layer-base">
                    {
                        groups
                            .filter((grp) => grp.g !== "2")
                            .map((grp) => (
                                <g data-group={grp.g}>
                                    {grp.paths.map((d) => (
                                        <path d={d} />
                                    ))}
                                </g>
                            ))
                    }
                </g>
                <g class="layer-main">
                    {
                        groups.map((grp) =>
                            grp.g === "2" ? (
                                <g data-group="2" class="animated-group">
                                    <path
                                        class="animated"
                                        d={mergedGroup2}
                                        pathLength="1000"
                                        stroke-dasharray="1000 1000"
                                        stroke-dashoffset="1000"
                                    />
                                </g>
                            ) : (
                                <g data-group={grp.g}>
                                    {grp.paths.map((d) => (
                                        <path d={d} />
                                    ))}
                                </g>
                            ),
                        )
                    }
                </g>
                <g class="layer-highlight">
                    {
                        groups.map((grp) => (
                            <g data-group={grp.g}>
                                {grp.paths.map((d) => (
                                    <path d={d} />
                                ))}
                            </g>
                        ))
                    }
                </g>
            </svg>
        </div>

        <span class="hero-corner outer top-left" aria-hidden="true"></span>
        <span class="hero-corner outer top-right" aria-hidden="true"></span>
        <span class="hero-corner outer bottom-left" aria-hidden="true"></span>
        <span class="hero-corner outer bottom-right" aria-hidden="true"></span>
        <span class="hero-corner inner top-left" aria-hidden="true"></span>
        <span class="hero-corner inner top-right" aria-hidden="true"></span>
        <span class="hero-corner inner bottom-left" aria-hidden="true"></span>
        <span class="hero-corner inner bottom-right" aria-hidden="true"></span>

        <div class="hero-scroll-hint" aria-hidden="true">
            <span class="label">[Scroll]</span>
            <span class="tick"></span>
        </div>
    </section>
</div>
