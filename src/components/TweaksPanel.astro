---
---
<button id="tweaks-toggle" type="button">Tweaks</button>

<div id="tweaks-panel">
  <h4>
    Tweaks
    <button class="close" type="button" style="color:var(--muted)">×</button>
  </h4>

  <div class="tweak-group">
    <label>Background grid</label>
    <div class="seg three">
      <button data-k="grid" data-v="visible" class="active">Visible</button>
      <button data-k="grid" data-v="subtle">Subtle</button>
      <button data-k="grid" data-v="off">Off</button>
    </div>
  </div>

  <div class="tweak-group">
    <label>Hero grid size</label>
    <div class="seg three">
      <button data-k="heroGrid" data-v="4" class="active">4px</button>
      <button data-k="heroGrid" data-v="6">6px</button>
      <button data-k="heroGrid" data-v="8">8px</button>
    </div>
  </div>

  <div class="tweak-group">
    <label>Hero focus</label>
    <div class="seg">
      <button data-k="hero" data-v="dark" class="active">Dense left</button>
      <button data-k="hero" data-v="light">Centre</button>
    </div>
  </div>

  <div class="tweak-group">
    <label>H1 tone</label>
    <div class="seg">
      <button data-k="h1" data-v="a" class="active">Computed.</button>
      <button data-k="h1" data-v="b">Delivered.</button>
    </div>
  </div>

  <div class="tweak-group">
    <label>Accent</label>
    <div class="seg three">
      <button data-k="accent" data-v="#D85A1B" class="active">Pigment</button>
      <button data-k="accent" data-v="#E87C3C">Logo</button>
      <button data-k="accent" data-v="#14120F">Mono</button>
    </div>
  </div>
</div>
