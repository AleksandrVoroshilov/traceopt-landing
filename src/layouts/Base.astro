---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Traceopt — Optimal tracer routing' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo+Narrow:wght@400;500;600;700&family=Inter:wght@400;450;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body>
    <slot />

    <script>
      import { initParticleCanvas } from '../scripts/particle-canvas';
      import { initTweaks }         from '../scripts/tweaks';
      import { initForm }           from '../scripts/form';

      initTweaks();
      initForm();
      initParticleCanvas();
    </script>
  </body>
</html>
